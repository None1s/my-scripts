-- ═══════════════════════════════════════════════════
--  REMOTES
-- ═══════════════════════════════════════════════════

function v1.FireRemote(name, ...)
    local targets = {S.ReplicatedStorage}
    for _, d in ipairs(S.RepicatedStorage:GetDescendants()) do
        if d.Name == name and d:IsA("RemoteEvent") then
            d:FireServer(...)
            return true
        end
    end
    -- Fallback: direct child
    local r = S.ReplicatedStorage:FindFirstChild(name)
    if r and r:IsA("RemoteEvent") then r:FireServer(...) return true end
    return false
end

function v1.InvokeRemote(name, ...)
    for _, d in ipairs(S.ReplicatedStorage:GetDescendants()) do
        if d.Name == name and d:IsA("RemoteFunction") then
            return d:InvokeServer(...)
        end
    end
    return nil
end

-- ═══════════════════════════════════════════════════
--  INPUT
-- ═══════════════════════════════════════════════════

function v1.OnKeyPress(keyCode, callback)
    local conn = S.UserInputService.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == keyCode then callback(input) end
    end)
    table.insert(Connections, conn)
    return conn
end

function v1.OnKeyRelease(keyCode, callback)
    local conn = S.UserInputService.InputEnded:Connect(function(input, processed)
        if not processed and input.KeyCode == keyCode then callback(input) end
    end)
    table.insert(Connections, conn)
    return conn
end

-- ═══════════════════════════════════════════════════
--  EVENTS
-- ═══════════════════════════════════════════════════

function v1.Connect(signal, callback)
    local conn = signal:Connect(callback)
    table.insert(Connections, conn)
    return conn
end

function v1.OnCharacterAdded(callback)
    if P.Character then task.spawn(callback, P.Character) end
    v1.Connect(P.CharacterAdded, function(char) task.spawn(callback, char) end)
    return v1
end

function v1.OnPlayerAdded(callback)
    for _, p in ipairs(S.Players:GetPlayers()) do task.spawn(callback, p) end
    v1.Connect(S.Players.PlayerAdded, callback)
    return v1
end

-- ═══════════════════════════════════════════════════
--  LOOPS
-- ═══════════════════════════════════════════════════

function v1.HeartbeatLoop(callback)
    local conn
    conn = S.RunService.Heartbeat:Connect(function(dt)
        if callback(dt) == false then conn:Disconnect() end
    end)
    table.insert(Connections, conn)
    return conn
end

function v1.RenderSteppedLoop(callback)
    local conn
    conn = S.RunService.RenderStepped:Connect(function(dt)
        if callback(dt) == false then conn:Disconnect() end
    end)
    table.insert(Connections, conn)
    return conn
end

function v1.RepeatEvery(interval, callback)
    local running = true
    task.spawn(function()
        while running do
            callback()
            task.wait(interval)
        end
    end)
    return { Stop = function() running = false end }
end

-- ═══════════════════════════════════════════════════
--  RAYCAST
-- ═══════════════════════════════════════════════════

function v1.Raycast(origin, direction, params)
    return S.Workspace:Raycast(origin, direction, params or RaycastParams.new())
end

function v1.RaycastFromCamera(distance, params)
    local cam = S.Workspace.CurrentCamera
    local mouse = S.UserInputService:GetMouseLocation()
    local ray = cam:ViewportPointToRay(mouse.X, mouse.Y)
    return S.Workspace:Raycast(ray.Origin, ray.Direction * (distance or 1000), params or RaycastParams.new())
end

-- ═══════════════════════════════════════════════════
--  MATH
-- ═══════════════════════════════════════════════════

function v1.Distance(a, b)           return (a - b).Magnitude end
function v1.Direction(from, to)      return (to - from).Unit end
function v1.Lerp(a, b, alpha)        return a + (b - a) * alpha end
function v1.Clamp(val, min, max)     return math.clamp(val, min, max) end

