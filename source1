function v1.AntiAFK()
    P.Idled:Connect(function()
        S.VirtualUser:CaptureController()
        S.VirtualUser:ClickButton2(Vector2.new())
        v1.Log("Anti-AFK triggered")
    end)
    return v1
end

function v1.Log(...)   print("[v1]", ...)  return v1 end
function v1.Warn(...)  warn("[v1]", ...)  return v1 end

