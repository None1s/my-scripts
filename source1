--[[
    ATERUS UI LIBRARY v1.0.0
    A satisfying, high-performance dark mode framework.
    (Fixed visibility & Executor compatibility)
--]]

local AterusLib = {}
AterusLib.__index = AterusLib

-- [ SERVICES ]
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

-- [ UTILITIES ]
local function Ripple(obj)
    task.spawn(function()
        local mouse = Players.LocalPlayer:GetMouse()
        local circle = Instance.new("ImageLabel")
        circle.Parent = obj
        circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        circle.BackgroundTransparency = 0.8
        circle.ZIndex = 10
        circle.Image = "rbxassetid://266543268"
        circle.ImageColor3 = Color3.fromRGB(255, 255, 255)
        circle.ImageTransparency = 0.9
        
        local x = mouse.X - circle.AbsolutePosition.X
        local y = mouse.Y - circle.AbsolutePosition.Y
        circle.Position = UDim2.new(0, x, 0, y)
        
        local size = obj.AbsoluteSize.X > obj.AbsoluteSize.Y and obj.AbsoluteSize.X or obj.AbsoluteSize.Y
        circle:TweenSizeAndPosition(UDim2.new(0, size*2, 0, size*2), UDim2.new(0.5, -size, 0.5, -size), "Out", "Quad", 0.5, false)
        for i = 1, 10 do
            circle.ImageTransparency = circle.ImageTransparency + 0.01
            circle.BackgroundTransparency = circle.BackgroundTransparency + 0.02
            task.wait(0.01)
        end
        circle:Destroy()
    end)
end

-- [ LIBRARY MAIN FUNCTION ]
function AterusLib.CreateWindow(title)
    local self = setmetatable({}, AterusLib)
    
    -- Random ID for Stealth
    local UI_ID = "AT_" .. math.random(1e5, 9e5)
    
    -- Root UI
    self.ScreenGui = Instance.new("ScreenGui")
    self.ScreenGui.Name = UI_ID
    self.ScreenGui.ResetOnSpawn = false
    self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    self.ScreenGui.IgnoreGuiInset = true

    -- [ %100 VISIBILITY FIX ]
    pcall(function()
        if RunService:IsStudio() then
            self.ScreenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
        else
            if gethui then
                self.ScreenGui.Parent = gethui()
            elseif syn and syn.protect_gui then
                syn.protect_gui(self.ScreenGui)
                self.ScreenGui.Parent = CoreGui
            else
                self.ScreenGui.Parent = CoreGui
            end
        end
    end)
    -- Fallback just in case
    if not self.ScreenGui.Parent then
        self.ScreenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
    end

    -- Main Frame
    self.Main = Instance.new("Frame")
    self.Main.Size = UDim2.new(0, 210, 0, 300)
    self.Main.Position = UDim2.new(0.5, -105, 0.5, -150)
    self.Main.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    self.Main.BorderSizePixel = 0
    self.Main.ClipsDescendants = true
    self.Main.Parent = self.ScreenGui
    Instance.new("UICorner", self.Main).CornerRadius = UDim.new(0, 10)
    local stroke = Instance.new("UIStroke", self.Main)
    stroke.Color = Color3.fromRGB(30, 30, 30)
    stroke.Thickness = 1.2

    -- Header
    self.Header = Instance.new("Frame")
    self.Header.Size = UDim2.new(1, 0, 0, 35)
    self.Header.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    self.Header.Parent = self.Main
    Instance.new("UICorner", self.Header).CornerRadius = UDim.new(0, 10)

    self.Title = Instance.new("TextLabel")
    self.Title.Size = UDim2.new(1, -40, 1, 0)
    self.Title.Position = UDim2.new(0, 15, 0, 0)
    self.Title.BackgroundTransparency = 1
    self.Title.Text = title or "ATERUS UI"
    self.Title.Font = Enum.Font.Code
    self.Title.TextColor3 = Color3.fromRGB(200, 200, 200)
    self.Title.TextSize = 13
    self.Title.TextXAlignment = Enum.TextXAlignment.Left
    self.Title.Parent = self.Header

    -- Minimize
    self.MinBtn = Instance.new("TextButton")
    self.MinBtn.Size = UDim2.new(0, 35, 0, 35)
    self.MinBtn.Position = UDim2.new(1, -35, 0, 0)
    self.MinBtn.BackgroundTransparency = 1
    self.MinBtn.Text = "-"
    self.MinBtn.Font = Enum.Font.Code
    self.MinBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    self.MinBtn.TextSize = 20
    self.MinBtn.Parent = self.Header

    -- Scrolling Container
    self.Container = Instance.new("ScrollingFrame")
    self.Container.Size = UDim2.new(1, -20, 1, -50)
    self.Container.Position = UDim2.new(0, 10, 0, 45)
    self.Container.BackgroundTransparency = 1
    self.Container.ScrollBarThickness = 0
    self.Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    self.Container.CanvasSize = UDim2.new(0, 0, 0, 0)
    self.Container.Parent = self.Main
    local list = Instance.new("UIListLayout", self.Container)
    list.Padding = UDim.new(0, 6)
    list.SortOrder = Enum.SortOrder.LayoutOrder

    -- Smooth Dragging Logic
    local dragging, dragStart, startPos
    self.Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = self.Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            TweenService:Create(self.Main, TweenInfo.new(0.1), {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}):Play()
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    -- Minimize Logic
    local minimized = false
    self.MinBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        local targetSize = minimized and UDim2.new(0, 210, 0, 35) or UDim2.new(0, 210, 0, 300)
        TweenService:Create(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = targetSize}):Play()
        self.MinBtn.Text = minimized and "+" or "-"
    end)

    return self
end

-- [ ADD BUTTON ]
function AterusLib:Button(name, callback)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 0, 32)
    Btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Btn.Text = name
    Btn.Font = Enum.Font.Code
    Btn.TextColor3 = Color3.fromRGB(160, 160, 160)
    Btn.TextSize = 12
    Btn.AutoButtonColor = false
    Btn.Parent = self.Container
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    
    local stroke = Instance.new("UIStroke", Btn)
    stroke.Color = Color3.fromRGB(35, 35, 35)

    Btn.MouseEnter:Connect(function() TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(0, 255, 150)}):Play() end)
    Btn.MouseLeave:Connect(function() TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(35, 35, 35)}):Play() end)
    
    Btn.MouseButton1Click:Connect(function()
        Ripple(Btn)
        if callback then callback() end
    end)
end

-- [ ADD TOGGLE ]
function AterusLib:Toggle(name, default, callback)
    local state = default or false
    local TglBtn = Instance.new("TextButton")
    TglBtn.Size = UDim2.new(1, 0, 0, 32)
    TglBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    TglBtn.Text = "  " .. name
    TglBtn.Font = Enum.Font.Code
    TglBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
    TglBtn.TextSize = 12
    TglBtn.TextXAlignment = Enum.TextXAlignment.Left
    TglBtn.AutoButtonColor = false
    TglBtn.Parent = self.Container
    Instance.new("UICorner", TglBtn).CornerRadius = UDim.new(0, 6)

    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 10, 0, 10)
    Indicator.Position = UDim2.new(1, -20, 0.5, -5)
    Indicator.BackgroundColor3 = state and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(40, 40, 40)
    Indicator.Parent = TglBtn
    Instance.new("UICorner", Indicator).CornerRadius = UDim.new(1, 0)

    TglBtn.MouseButton1Click:Connect(function()
        state = not state
        local targetColor = state and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(40, 40, 40)
        TweenService:Create(Indicator, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        if callback then callback(state) end
    end)
end

return AterusLib
