end

-- ═══════════════════════════════════════════════════
--  UTILITY
-- ═══════════════════════════════════════════════════

function v1.Wait(seconds)
    task.wait(seconds)
    return v1
end

function v1.Defer(seconds, callback)
    task.delay(seconds, callback)
    return v1
end

function v1.Spawn(callback)
    task.spawn(callback)
    return v1
end

function v1.Tween(object, properties, duration, easingStyle, easingDirection)
    duration = duration or 1
    easingStyle = easingStyle or Enum.EasingStyle.Quad
    easingDirection = easingDirection or Enum.EasingDirection.Out
    local tween = S.TweenService:Create(object, TweenInfo.new(duration, easingStyle, easingDirection), properties)
    tween:Play()
    return tween
end

function v1.GetInstance(path, timeout)
    timeout = timeout or 10
    local parts = string.split(path, ".")
    local current = game
    for _, part in ipairs(parts) do
        local child = current:FindFirstChild(part) or current:WaitForChild(part, timeout)
        if not child then return nil end
        current = child
    end
    return current
end

function v1.DisconnectAll()
    for _, conn in ipairs(Connections) do
        if conn.Connected then conn:Disconnect() end
    end
    Connections = {}
    return v1
end

-- ═══════════════════════════════════════════════════
--  PLAYER
-- ═══════════════════════════════════════════════════

function v1.GetLocalPlayer()
    return P
end

function v1.GetCharacter(player)
    player = player or P
    return player.Character or player.CharacterAdded:Wait()
end

function v1.GetHumanoid(player)
    player = player or P
    local c = v1.GetCharacter(player)
    return c and c:FindFirstChildOfClass("Humanoid") or nil
end

function v1.GetRootPart(player)
    player = player or P
    local c = v1.GetCharacter(player)
    return c and c:FindFirstChild("HumanoidRootPart") or nil
end

function v1.IsAlive(player)
    local h = v1.GetHumanoid(player)
    return h and h.Health > 0
end

function v1.GetHealth(player)
    local h = v1.GetHumanoid(player)
    return h and h.Health or 0, h and h.MaxHealth or 0
end

function v1.GetPosition(player)
    local r = v1.GetRootPart(player)
    return r and r.Position or Vector3.zero
end

function v1.GetPlayers()
    return S.Players:GetPlayers()
end

function v1.GetPlayerByName(name)
    local lower = string.lower(name)
    for _, p in ipairs(S.Players:GetPlayers()) do
        if string.lower(p.Name) == lower or string.lower(p.DisplayName) == lower then
            return p
        end
    end
    return nil
end

function v1.GetNearestPlayer(maxDistance, ignoreList)
    maxDistance = maxDistance or math.huge
    ignoreList = ignoreList or {}
    local myRoot = v1.GetRootPart()
    if not myRoot then return nil, 0 end
    local nearest, nearestDist = nil, maxDistance
    for _, p in ipairs(S.Players:GetPlayers()) do
        if p ~= P and not table.find(ignoreList, p) then
            local r = v1.GetRootPart(p)
            if r and v1.IsAlive(p) then
                local d = (r.Position - myRoot.Position).Magnitude
                if d < nearestDist then
                    nearest, nearestDist = p, d
                end
            end
        end
    end
    return nearest, nearestDist
end

-- ═══════════════════════════════════════════════════
--  MOVEMENT
-- ═══════════════════════════════════════════════════

function v1.TeleportTo(position, player)
    local r = v1.GetRootPart(player or P)
    if r then r.CFrame = CFrame.new(position) end
    return v1
end

function v1.TeleportToPlayer(targetPlayer)
    local r = v1.GetRootPart(targetPlayer)
    if r then v1.TeleportTo(r.Position + Vector3.new(3, 0, 0)) end
    return v1
end

function v1.WalkTo(position, player)
    local h = v1.GetHumanoid(player or P)
    if h then h:MoveTo(position) end
    return v1
end

function v1.SetWalkSpeed(speed, player)
    local h = v1.GetHumanoid(player or P)
    if h then h.WalkSpeed = speed end
    return v1
end

function v1.SetJumpPower(power, player)
    local h = v1.GetHumanoid(player or P)
    if h then h.JumpPower = power end
    return v1
end

function v1.SetGravity(value)
    S.Workspace.Gravity = value
    return v1
end

function v1.GetGravity()
    return S.Workspace.Gravity
end

